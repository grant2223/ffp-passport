# HTML files: NEVER cache anywhere. Force fresh fetch every visit.
# Three directives (no-store + no-cache + Pragma + Expires) to handle
# legacy browsers + iOS Safari's aggressive cache + intermediate CDNs.
# During active development we want every push to land on every device
# the next time the user opens the page.

/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# JS files in assets: same — never cache while we're iterating quickly.
# At production stability, switch to long max-age + versioned filenames
# (e.g. ffp-earnings-loader.v12.js) for proper cache-busting.
/assets/*.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

# CSS — same as JS, no cache during dev
/assets/*.css
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache

# Images: cache for 24 hours since they rarely change.
/assets/*.png
  Cache-Control: public, max-age=86400

/assets/*.jpg
  Cache-Control: public, max-age=86400

/assets/*.jpeg
  Cache-Control: public, max-age=86400

/assets/*.svg
  Cache-Control: public, max-age=86400

/assets/*.webp
  Cache-Control: public, max-age=86400
